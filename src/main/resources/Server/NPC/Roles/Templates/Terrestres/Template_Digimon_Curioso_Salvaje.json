                    "Actions": [
                      {
                        "Type": "State",
                        "State": "Sleep"
                      }
                    ]
                  }
                }
              ]
            }
          ]
        },
        {
          "$Comment": "ESTADO CURIOSO: Se acerca lentamente al jugador. Huye si lo atacan.",
          "Sensor": {
            "Type": "State",
            "State": "Curious"
          },
          "Instructions": [
            {
              "$Comment": "Animacion y particulas de curiosidad — una sola vez al entrar",
              "Continue": true,
              "Sensor": {
                "Type": "Any",
                "Once": true
              },
              "Actions": [
                {
                  "Type": "PlayAnimation",
                  "Slot": "Status",
                  "Animation": "Alerted"
                },
                {
                  "Type": "SpawnParticles",
                  "Offset": [
                    0,
                    0.8,
                    0
                  ],
                  "ParticleSystem": "Question"
                }
              ]
            },
            {
              "$Comment": "Si lo atacan en este estado, huye inmediatamente",
              "Sensor": {
                "Type": "Damage",
                "Combat": true
              },
              "Actions": [
                {
                  "Type": "State",
                  "State": "Flee"
                }
              ]
            },
            {
              "$Comment": "Mira al jugador mientras se acerca",
              "Continue": true,
              "Sensor": {
                "Type": "Target",
                "Range": {
                  "Compute": "AlertedRange"
                },
                "Filters": [
                  {
                    "Type": "LineOfSight"
                  }
                ]
              },
              "HeadMotion": {
                "Type": "Watch"
              }
            },
            {
              "$Comment": "Se aproxima lentamente al jugador cuando esta en rango",
              "Continue": true,
              "Sensor": {
                "Type": "Target",
                "Range": {
                  "Compute": "AlertedRange"
                }
              },
              "BodyMotion": {
                "Type": "Seek",
                "SlowDownDistance": {
                  "Compute": "CuriousStopDistance + 2"
                },
                "StopDistance": {
                  "Compute": "CuriousStopDistance"
                },
                "RelativeSpeed": {
                  "Compute": "CuriousApproachSpeed"
                }
              }
            },
            {
              "$Comment": "Tiempo maximo de curiosidad — pierde interes y vuelve a idle",
              "Sensor": {
                "Type": "Target",
                "Range": {
                  "Compute": "AlertedRange"
                }
              },
              "Actions": [
                {
                  "Type": "Timeout",
                  "Delay": {
                    "Compute": "CuriousTimeRange"
                  },
                  "Action": {
                    "Type": "State",
                    "State": "Idle"
                  }
                }
              ]
            },
            {
              "$Comment": "Si el jugador se aleja, vuelve a idle tras un momento",
              "Sensor": {
                "Type": "Not",
                "Sensor": {
                  "Type": "Target",
                  "Range": {
                    "Compute": "AlertedRange"
                  }
                }
              },
              "ActionsAtomic": true,
              "Actions": [
                {
                  "Type": "Timeout",
                  "Delay": [
                    1,
                    1
                  ]
                },
                {
                  "Type": "State",
                  "State": "Idle"
                }
              ]
            }
          ]
        },
        {
          "$Comment": "ESTADO HUIDA: Corre alejandose del jugador",
          "Sensor": {
            "Type": "State",
            "State": "Flee"
          },
          "Instructions": [
            {
              "Continue": true,
              "Sensor": {
                "Type": "Any",
                "Once": true
              },
              "Actions": [
                {
                  "Type": "PlayAnimation",
                  "Slot": "Status"
                }
              ]
            },
            {
              "$Comment": "Si lo siguen golpeando, busca el objetivo y huye de el",
              "Sensor": {
                "Type": "Target",
                "Range": {
                  "Compute": "AlertedRange"
                }
              },
              "BodyMotion": {
                "Type": "Flee",
                "SlowDownDistance": {
                  "Compute": "AlertedRange - 3"
                },
                "StopDistance": {
                  "Compute": "AlertedRange + 2"
                },
                "RelativeSpeed": {
                  "Compute": "FleeRelativeSpeed"
                }
              },
              "Actions": [
                {
                  "Type": "Timeout",
                  "Delay": [
                    6,
                    8
                  ],
                  "Action": {
                    "Type": "State",
                    "State": "Idle"
                  }
                }
              ]
            },
            {
              "$Comment": "Si el jugador ya no esta en rango, regresa a idle",
              "Actions": [
                {
                  "Type": "State",
                  "State": "Idle"
                }
              ]
            }
          ]
        },
        {
          "$Comment": "ESTADO PANICO: Huida caotica tras dano inesperado",
          "Sensor": {
            "Type": "State",
            "State": "Panic"
          },
          "Instructions": [
            {
              "Continue": true,
              "Sensor": {
                "Type": "Any",
                "Once": true
              },
              "Actions": [
                {
                  "Type": "PlayAnimation",
                  "Slot": "Status",
                  "Animation": "Alerted"
                }
              ]
            },
            {
              "Continue": true,
              "Actions": [
                {
                  "Type": "Timeout",
                  "Delay": [
                    5,
                    8
                  ],
                  "Action": {
                    "Type": "State",
                    "State": "Idle"
                  }
                }
              ]
            },
            {
              "Sensor": {
                "Type": "Damage",
                "Combat": true
              },
              "BodyMotion": {
                "Type": "Flee",
                "SlowDownDistance": 8,
                "StopDistance": 14,
                "RelativeSpeed": 1.0,
                "RelaxedMoveConstraints": false
              }
            },
            {
              "BodyMotion": {
                "Type": "WanderInCircle",
                "Radius": 10,
                "MaxHeadingChange": 90,
                "RelativeSpeed": 1.0,
                "RelaxedMoveConstraints": true
              }
            }
          ]
        },
        {
          "$Comment": "ESTADO SLEEP: Comportamiento de sueno. Mismo patron que templates base.",
          "Sensor": {
            "Type": "State",
            "State": "Sleep"
          },
          "Instructions": [
            {
              "Enabled": {
                "Compute": "DayTimeNapWeight > 0"
              },
              "Sensor": {
                "Type": "State",
                "State": ".Nap"
              },
              "Instructions": [
                {
                  "Continue": true,
                  "Sensor": {
                    "Type": "Any",
                    "Once": true
                  },
                  "Actions": [
                    {
                      "Type": "TimerStart",
                      "Name": "NapTimer",
                      "StartValueRange": {
                        "Compute": "DayTimeNapTimeRange"
                      },
                      "RestartValueRange": {
                        "Compute": "DayTimeNapTimeRange"
                      }
                    },
                    {
                      "Type": "TimerRestart",
                      "Name": "NapTimer"
                    }
                  ]
                },
                {
                  "Reference": "Component_Instruction_Wild_Sleep_State",
                  "Modify": {
                    "_ExportStates": [
                      "Flee",
                      "Panic",
                      "Curious",
                      "Idle"
                    ],
                    "HearingRange": {
                      "Compute": "HearingRange"
                    },
                    "Attitudes": [
                      "Hostile"
                    ],
                    "WakeupSensor": "Component_Sensor_Timed_Nap"
                  }
                }
              ]
            },
            {
              "Instructions": [
                {
                  "Reference": "Component_Instruction_Wild_Sleep_State",
                  "Modify": {
                    "_ExportStates": [
                      "Flee",
                      "Panic",
                      "Curious",
                      "Idle"
                    ],
                    "HearingRange": {
                      "Compute": "HearingRange"
                    },
                    "Attitudes": [
                      "Hostile"
                    ],
                    "DayTimePeriod": {
                      "Compute": "DayTimePeriod"
                    }
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "NameTranslationKey": {
    "Compute": "NameTranslationKey"
  }
