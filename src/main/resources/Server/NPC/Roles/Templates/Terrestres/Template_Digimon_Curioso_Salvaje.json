                        {
                          "Type": "State",
                          "State": "Sleep.Nap"
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "$Comment": "Duerme de noche",
              "Enabled": {
                "Compute": "AlwaysSleepAtNight"
              },
              "Actions": [
                {
                  "Type": "Timeout",
                  "Delay": [
                    2,
                    4
                  ],
                  "Action": {
