{
  "Type": "Abstract",
  "StartState": "Idle",
  "Parameters": {
    "Appearance": {
      "Value": "Greymon_Model",
      "Description": "Modelo visual del Digimon"
    },
    "MaxHealth": {
      "Value": 100,
      "Description": "Salud maxima"
    },
    "ViewRange": {
      "Value": 20,
      "Description": "Rango de vision"
    },
    "ViewSector": {
      "Value": 180,
      "Description": "Sector de vision en grados"
    },
    "HearingRange": {
      "Value": 10,
      "Description": "Rango de oido"
    },
    "AbsoluteDetectionRange": {
      "Value": 5,
      "Description": "Rango de deteccion garantizada"
    },
    "AlertedRange": {
      "Value": 24,
      "Description": "Rango alerta"
    },
    "FollowItemDistance": {
      "Value": [
        3,
        4.5
      ],
      "Description": "Distancia al seguir al jugador"
    },
    "MaxSpeed": {
      "Value": 7,
      "Description": "Velocidad maxima"
    },
    "ParticleOffset": {
      "Value": [
        0,
        1.2,
        0
      ],
      "Description": "Offset de particulas (mas alto por el mayor tamano del modelo)"
    },
    "PetAnimation": {
      "Value": "Curious",
      "Description": "Animacion al ser acariciado"
    },
    "PetTimeout": {
      "Value": [
        "PT1M",
        "PT1M"
      ],
      "Description": "Cooldown entre pets (formato ISO 8601)"
    },
    "PetRequiredAttitudes": {
      "Value": [
        "Friendly",
        "Revered"
      ],
      "Description": "Actitudes que pueden acariciar"
    },
    "AttractiveItemSet": {
      "Value": [
        "Tool_Feedbag"
      ],
      "Description": "Items que atraen al Digimon para ser alimentado"
    },
    "FeedRequiredAttitudes": {
      "Value": [
        "Friendly",
        "Revered"
      ],
      "Description": "Actitudes que pueden alimentar al Digimon"
    },
    "EatTimeout": {
      "Value": [
        "PT4H",
        "PT8H"
      ],
      "Description": "Cooldown entre comidas (formato ISO 8601)"
    },
    "AttitudeGroup": {
      "Value": "Prey",
      "Description": "Grupo de actitud"
    },
    "DropList": {
      "Value": "Empty",
      "Description": "Items al morir"
    },
    "IsMemory": {
      "Value": false,
      "Description": "Si es un recuerdo"
    },
    "MemoriesCategory": {
      "Value": "Other",
      "Description": "Categoria del recuerdo"
    },
    "MemoriesNameOverride": {
      "Value": "",
      "Description": "Nombre override del recuerdo"
    },
    "IsMountable": {
      "Value": false,
      "Description": "Si el Digimon puede ser montado. Activar en variantes Champion/Ultimate/Mega."
    },
    "MountAnchorX": {
      "Value": 0,
      "Description": "Offset X del punto de montaje"
    },
    "MountAnchorY": {
      "Value": 1.8,
      "Description": "Offset Y del punto de montaje (altura de la silla)"
    },
    "MountAnchorZ": {
      "Value": 0,
      "Description": "Offset Z del punto de montaje"
    },
    "MountMovementConfig": {
      "Value": "Mount",
      "Description": "Configuracion de movimiento al montar"
    },
    "NameTranslationKey": {
      "Value": "server.npcRoles.Template.name",
      "Description": "Clave de nombre"
    }
  },
  "modules": {
    "hytale:memories": {
      "memory_duration": {
        "PLAYER_LAST_FED": 14400,
        "PLAYER_LAST_PET": 6000,
        "PLAYER_HIT": 24000
      }
    }
  },
  "IsMemory": {
    "Compute": "IsMemory"
  },
  "MemoriesCategory": {
    "Compute": "MemoriesCategory"
  },
  "MemoriesNameOverride": {
    "Compute": "MemoriesNameOverride"
  },
  "DropList": {
    "Compute": "DropList"
  },
  "Appearance": {
    "Compute": "Appearance"
  },
  "DefaultPlayerAttitude": "Revered",
  "DefaultNPCAttitude": "Ignore",
  "AttitudeGroup": {
    "Compute": "AttitudeGroup"
  },
  "DisableDamageGroups": [
    "Self"
  ],
  "KnockbackScale": 0.3,
  "MotionControllerList": [
    {
      "Type": "Walk",
      "MaxWalkSpeed": {
        "Compute": "MaxSpeed"
      },
      "Gravity": 12,
      "MaxFallSpeed": 10,
      "Acceleration": 12,
      "MaxRotationSpeed": 360
    }
  ],
  "MaxHealth": {
    "Compute": "MaxHealth"
  },
  "StateTransitions": [
    {
      "States": [
        {
          "To": [
            "Idle"
          ],
          "From": []
        }
      ],
      "Actions": [
        {
          "Type": "ReleaseTarget"
        },
        {
          "Type": "ResetInstructions"
        },
        {
          "Type": "PlayAnimation",
          "Slot": "Status"
        }
      ]
    }
  ],
  "Instructions": [
    {
      "$Comment": "Limpiar alarma de Pet cuando termina",
      "Continue": true,
      "Instructions": [
        {
          "Continue": true,
          "Sensor": {
            "Type": "Alarm",
            "Name": "Pet_Ready",
            "State": "Passed",
            "Clear": true
          },
          "Actions": [
            {
              "Type": "Nothing"
            }
          ]
        },
        {
          "$Comment": "Limpiar alarma de Eat cuando termina",
          "Continue": true,
          "Sensor": {
            "Type": "Alarm",
            "Name": "Eat_Ready",
            "State": "Passed",
            "Clear": true
          },
          "Actions": [
            {
              "Type": "Nothing"
            }
          ]
        }
      ]
    },
    {
      "Instructions": [
        {
          "Sensor": {
            "Type": "State",
            "State": "Idle"
          },
          "Instructions": [
            {
              "$Comment": "Detectar jugadores amigables y seguirlos",
              "Continue": true,
              "Sensor": {
                "Reference": "Component_Sensor_Standard_Detection",
                "Modify": {
                  "ViewRange": {
                    "Compute": "ViewRange"
                  },
                  "ViewSector": {
                    "Compute": "ViewSector"
                  },
                  "HearingRange": {
                    "Compute": "HearingRange"
                  },
                  "AbsoluteDetectionRange": {
                    "Compute": "AbsoluteDetectionRange"
                  },
                  "Attitudes": [
                    "Revered",
                    "Friendly"
                  ],
                  "GetNPCs": false
                }
              },
              "Instructions": [
                {
                  "Sensor": {
                    "Type": "Target",
                    "Filters": [
                      {
                        "Type": "Attitude",
                        "Attitudes": [
                          "Revered",
                          "Friendly"
                        ]
                      }
                    ]
                  },
                  "HeadMotion": {
                    "Type": "Watch"
                  },
                  "BodyMotion": {
                    "Type": "MaintainDistance",
                    "DesiredDistanceRange": {
                      "Compute": "FollowItemDistance"
                    },
                    "RelativeForwardsSpeed": 0.6,
                    "RelativeBackwardsSpeed": 0.4
                  },
                  "Actions": [
                    {
                      "Type": "PlayAnimation",
                      "Slot": "Status",
                      "Animation": "Curious"
                    }
                  ]
                }
              ]
            },
            {
              "$Comment": "Merodear cuando no hay jugador cercano",
              "BodyMotion": {
                "Type": "Sequence",
                "Looped": true,
                "Motions": [
                  {
                    "Type": "Timer",
                    "Time": [
                      2,
                      5
                    ],
                    "Motion": {
                      "Type": "WanderInCircle",
                      "Radius": 4,
                      "MaxHeadingChange": 60,
                      "RelativeSpeed": 0.2
                    }
                  },
                  {
                    "Type": "Timer",
                    "Time": [
                      2,
                      5
                    ],
                    "Motion": {
                      "Type": "Nothing"
                    }
                  }
                ]
              }
            }
          ]
        }
      ]
    }
  ],
  "InteractionInstruction": {
    "Instructions": [
      {
        "$Comment": "Siempre bloquear el objetivo de interaccion primero",
        "Continue": true,
        "Actions": [
          {
            "Type": "LockOnInteractionTarget",
            "TargetSlot": "InteractionTarget"
          }
        ]
      },
      {
        "$Comment": "--- BLOQUE PET ---",
        "TreeMode": true,
        "Instructions": [
          {
            "InvertTreeModeResult": true,
            "Sensor": {
              "Type": "Not",
              "Sensor": {
                "Type": "And",
                "Sensors": [
                  {
                    "Type": "Alarm",
                    "Name": "Pet_Ready",
                    "State": "Unset"
                  },
                  {
                    "Type": "CanInteract",
                    "Attitudes": {
                      "Compute": "PetRequiredAttitudes"
                    }
                  },
                  {
                    "Type": "Target",
                    "TargetSlot": "InteractionTarget",
                    "Filters": [
                      {
                        "Type": "Not",
                        "Filter": {
                          "Type": "ItemInHand",
                          "Hand": "Main",
                          "Items": [
                            "*"
                          ]
                        }
                      }
                    ]
                  }
                ]
              }
            },
            "Actions": [
              {
                "Type": "Nothing"
              }
            ]
          },
          {
            "InvertTreeModeResult": true,
            "Continue": true,
            "Sensor": {
              "Type": "Any"
            },
            "Actions": [
              {
                "Type": "SetInteractable",
                "Interactable": true,
                "Hint": "server.interactionHints.pet"
              }
            ]
          },
          {
            "Sensor": {
              "Type": "HasInteracted"
            },
            "Instructions": [
              {
                "Sensor": {
                  "Type": "Target"
                },
                "Actions": [
                  {
                    "Type": "PlayAnimation",
                    "Slot": "Status",
                    "Animation": {
                      "Compute": "PetAnimation"
                    }
                  },
                  {
                    "Type": "SpawnParticles",
                    "ParticleSystem": "Hearts_Subtle",
                    "Offset": {
                      "Compute": "ParticleOffset"
                    },
                    "TargetNodeName": "Head"
                  },
                  {
                    "Type": "SetAlarm",
                    "Name": "Pet_Ready",
                    "DurationRange": {
                      "Compute": "PetTimeout"
                    }
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "$Comment": "--- BLOQUE ALIMENTAR ---",
        "TreeMode": true,
        "Instructions": [
          {
            "InvertTreeModeResult": true,
            "Sensor": {
              "Type": "Not",
              "Sensor": {
                "Type": "And",
                "Sensors": [
                  {
                    "Type": "Alarm",
                    "Name": "Eat_Ready",
                    "State": "Unset"
                  },
                  {
                    "Type": "CanInteract",
                    "Attitudes": {
                      "Compute": "FeedRequiredAttitudes"
                    }
                  },
                  {
                    "Type": "Target",
                    "TargetSlot": "InteractionTarget",
                    "Filters": [
                      {
                        "Type": "ItemInHand",
                        "Hand": "Main",
                        "Items": {
                          "Compute": "AttractiveItemSet"
                        }
                      }
                    ]
                  }
                ]
              }
            },
            "Actions": [
              {
                "Type": "Nothing"
              }
            ]
          },
          {
            "InvertTreeModeResult": true,
            "Continue": true,
            "Sensor": {
              "Type": "Any"
            },
            "Actions": [
              {
                "Type": "SetInteractable",
                "Interactable": true,
                "Hint": "server.interactionHints.feed"
              }
            ]
          },
          {
            "Sensor": {
              "Type": "HasInteracted"
            },
            "Instructions": [
              {
                "Sensor": {
                  "Type": "Target",
                  "TargetSlot": "InteractionTarget"
                },
                "Actions": [
                  {
                    "Type": "Inventory",
                    "UseTarget": true,
                    "Operation": "RemoveHeldItem",
                    "Count": 1
                  },
                  {
                    "Type": "SpawnParticles",
                    "ParticleSystem": "Hearts_Subtle",
                    "Offset": {
                      "Compute": "ParticleOffset"
                    },
                    "TargetNodeName": "Head"
                  },
                  {
                    "Type": "SetStat",
                    "Stat": "Health",
                    "Value": {
                      "Compute": "MaxHealth"
                    }
                  },
                  {
                    "Type": "SetAlarm",
                    "Name": "Eat_Ready",
                    "DurationRange": {
                      "Compute": "EatTimeout"
                    }
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "$Comment": "--- BLOQUE MONTAR (solo activo si IsMountable = true) ---",
        "Enabled": {
          "Compute": "IsMountable"
        },
        "TreeMode": true,
        "Instructions": [
          {
            "InvertTreeModeResult": true,
            "Sensor": {
              "Type": "Not",
              "Sensor": {
                "Type": "And",
                "Sensors": [
                  {
                    "Type": "CanInteract",
                    "ViewSector": 360,
                    "Attitudes": [
                      "Revered",
                      "Friendly"
                    ]
                  }
                ]
              }
            },
            "Actions": [
              {
                "Type": "Nothing"
              }
            ]
          },
          {
            "InvertTreeModeResult": true,
            "Continue": true,
            "Sensor": {
              "Type": "Any"
            },
            "Actions": [
              {
                "Type": "SetInteractable",
                "Interactable": true,
                "Hint": "server.interactionHints.mount"
              }
            ]
          },
          {
            "Sensor": {
              "Type": "HasInteracted"
            },
            "Actions": [
              {
                "Type": "PlayAnimation",
                "Slot": "Status"
              },
              {
                "Type": "Mount",
                "AnchorX": {
                  "Compute": "MountAnchorX"
                },
                "AnchorY": {
                  "Compute": "MountAnchorY"
                },
                "AnchorZ": {
                  "Compute": "MountAnchorZ"
                },
                "MovementConfig": {
                  "Compute": "MountMovementConfig"
                }
              }
            ]
          }
        ]
      },
      {
        "$Comment": "Solo ahora que fallaron todas las interacciones posibles, desactivar interactividad.",
        "Actions": [
          {
            "Type": "SetInteractable",
            "Interactable": false
          }
        ]
      }
    ]
  },
  "NameTranslationKey": {
    "Compute": "NameTranslationKey"
  }
}
