$C = "../Common.ui";

Group {
  LayoutMode: CenterMiddle;
  $C.@Container #SapotamaPanel {
    Background: (Color: #7a6a9e);
    Anchor: (Width: 420, Height: 360);

    #Title {
      $C.@Title {
        @Text = "Sapotama";
      }
    }

    #Content {
      LayoutMode: Top;
      Label #LblPaseo {
        Anchor: (Height: 40);
        Text: "Pasear Companeros";
        Style: LabelStyle(FontSize: 14, TextColor: #d0e8ff, HorizontalAlignment: Center);
      }
      Label #LblEquipo {
        Anchor: (Height: 20, Top: 8);
        Text: "Equipo: Unknown";
        Style: LabelStyle(FontSize: 12, TextColor: #4aff7f);
      }
      $C.@TextButton #BtnPasear {
        Anchor: (Top: 20);
        Text: "Pasear / Recoger";
      }
      $C.@TextButton #BtnBatallar {
        Anchor: (Top: 18);
        Text: "Batallar";
      }
      $C.@TextButton #BtnEquipo {
        Anchor: (Top: 18);
        Text: "Ver Equipo";
      }
      $C.@TextButton #BtnCerrar {
        Anchor: (Top: 18);
        Background: (Color: #e14c4c);
        Padding: (Full: 0);
        Text: "Cerrar";
      }
    }
  }
}
