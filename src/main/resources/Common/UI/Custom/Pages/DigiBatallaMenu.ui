$C = "../Common.ui";

Group {
  LayoutMode: CenterMiddle;
  $C.@Container #BatallaPanel {
    Background: (Color: #8a5a6a);
    Anchor: (Width: 700, Height: 500);

    #Title {
      $C.@Title {
        @Text = "Batalla";
      }
    }

    #Content {
      LayoutMode: Top;
      Label #LblTurno { Anchor: (Height: 20); Text: "Turno: ---"; }
      Label #LblEnemigo { Anchor: (Height: 20); Text: "Enemigo: ---"; }
      Label #LblEnemHp { Anchor: (Height: 16); Text: "HP: ---"; }
      Label #LblBarraEnem { Anchor: (Height: 12); Text: "░░░░░░░░░░"; }
      Label #LblAlerta { Anchor: (Height: 16); Text: ""; }
      Label #LblNombreA { Anchor: (Height: 20); Text: "---"; }
      Label #LblBarraA { Anchor: (Height: 12); Text: "░░░░░░░░░░"; }
      Label #LblHpA { Anchor: (Height: 16); Text: "HP: ---"; }
      Label #LblOpA { Anchor: (Height: 16); Text: "OP: 0"; }
      Label #LblNombreB { Anchor: (Height: 20); Text: "---"; }
      Label #LblBarraB { Anchor: (Height: 12); Text: "░░░░░░░░░░"; }
      Label #LblHpB { Anchor: (Height: 16); Text: "HP: ---"; }
      Label #LblOpB { Anchor: (Height: 16); Text: "OP: 0"; }
      Label #LblLog { Anchor: (Height: 40); Text: "Log de combate..."; }
      Label #LblResultado { Anchor: (Height: 20); Text: ""; }
      $C.@TextButton #BtnSupport {
        Anchor: (Top: 4);
        Text: "Support";
      }
      $C.@TextButton #BtnOrderRing {
        Anchor: (Top: 4);
        Text: "Order Ring";
      }
      $C.@TextButton #BtnTacticaA {
        Anchor: (Top: 4);
        Text: "Tactica A";
      }
      $C.@TextButton #BtnTacticaB {
        Anchor: (Top: 4);
        Text: "Tactica B";
      }
      $C.@TextButton #BtnHuir {
        Background: (Color: #e14c4c);
        Padding: (Full: 0);
        Anchor: (Top: 4);
        Text: "Huir";
      }
    }
  }
}
