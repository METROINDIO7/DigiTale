$C = "../Common.ui";

Group {
  LayoutMode: CenterMiddle;
  $C.@Container #OrderPanel {
    Background: (Color: #8a7a4a);
    Anchor: (Width: 500, Height: 420);

    #Title {
      $C.@Title {
        @Text = "Orden de Batalla";
      }
    }

    #Content {
      LayoutMode: Top;
      Label #LblOpRingA { Anchor: (Height: 20); Text: "OP A: ---"; }
      Label #LblOpRingB { Anchor: (Height: 20); Text: "OP B: ---"; }
      Label #LblOpTotal { Anchor: (Height: 20); Text: "TOTAL: ---"; }
      Label { Anchor: (Height: 16); Text: "Costos:"; }
      Label #LblCosteGuard { Anchor: (Height: 12); Text: "Guard = ---"; }
      Label #LblCosteAttack { Anchor: (Height: 12); Text: "Order Attack = ---"; }
      Label #LblCosteSpecial { Anchor: (Height: 12); Text: "Special = ---"; }
      Label #LblCosteExe { Anchor: (Height: 12); Text: "ExE Fusion = ---"; }
      Label #LblExeEstado { Anchor: (Height: 16); Text: "ExE: ---"; }
      $C.@TextButton #BtnGuardA { Anchor: (Top: 4); Text: "Guard A"; }
      $C.@TextButton #BtnGuardB { Anchor: (Top: 4); Text: "Guard B"; }
      $C.@TextButton #BtnAttackA { Anchor: (Top: 4); Text: "Attack A"; }
      $C.@TextButton #BtnAttackB { Anchor: (Top: 4); Text: "Attack B"; }
      $C.@TextButton #BtnSpecialA { Anchor: (Top: 4); Text: "Special A"; }
      $C.@TextButton #BtnSpecialB { Anchor: (Top: 4); Text: "Special B"; }
      $C.@TextButton #BtnExe { Anchor: (Top: 4); Text: "ExE Fusion"; }
      $C.@TextButton #BtnCerrarRing {
        Background: (Color: #1a6a2a);
        Padding: (Full: 0);
        Anchor: (Top: 4);
        Text: "Cerrar";
      }
    }
  }
}
